[node name="Subtitle" type="Label" parent="Background/Margin/Panel/Content"]
layout_mode = 2
autowrap_mode = 3
text = "Upload a zip that contains scene_package.json and its referenced images. You can also upload a custom character sprite before entering the map."

[node name="PackageSection" type="VBoxContainer" parent="Background/Margin/Panel/Content"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PackageHeading" type="Label" parent="Background/Margin/Panel/Content/PackageSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "1. Scene zip"

[node name="PackageHelp" type="Label" parent="Background/Margin/Panel/Content/PackageSection"]
layout_mode = 2
autowrap_mode = 3
