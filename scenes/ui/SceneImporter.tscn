[node name="PackagePathRow" type="HBoxContainer" parent="Background/Margin/Panel/Content/PackageSection"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PackageValue" type="LineEdit" parent="Background/Margin/Panel/Content/PackageSection/PackagePathRow"]
