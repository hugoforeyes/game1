; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="TopDownRPG"
config/description="Top-down 2D RPG pixel game"
run/main_scene="res://scenes/ui/IntroScene.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoloads/GameManager.gd"
SaveManager="*res://autoloads/SaveManager.gd"
NPCConversationManager="*res://autoloads/NPCConversationManager.gd"
SettingsManager="*res://autoloads/SettingsManager.gd"
MusicManager="*res://autoloads/MusicManager.gd"
ChapterFlow="*res://autoloads/ChapterFlow.gd"
QuestManager="*res://autoloads/QuestManager.gd"
MinimapManager="*res://autoloads/MinimapManager.gd"
InventoryManager="*res://autoloads/InventoryManager.gd"
ObjectInteractionManager="*res://autoloads/ObjectInteractionManager.gd"
WorldInteractionManager="*res://autoloads/WorldInteractionManager.gd"
PartyManager="*res://autoloads/PartyManager.gd"
NarrativeState="*res://autoloads/NarrativeState.gd"
CutsceneDirector="*res://autoloads/CutsceneDirector.gd"
AnnouncementCenter="*res://autoloads/AnnouncementCenter.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=576
window/size/window_width_override=2048
window/size/window_height_override=1152
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/scale_mode="fractional"

[gui]

theme/custom_font="res://assets/fonts/BeVietnamPro-Regular.ttf"

[editor_plugins]

enabled=PackedStringArray("res://addons/intro_copy/plugin.cfg")

[input]

